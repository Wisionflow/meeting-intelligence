# ─── Required ─────────────────────────────────────────────────────────────────

# Claude API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=your_key_here

# Folder where new audio files appear
AUDIO_INBOX=/path/to/audio/inbox

# Folder where transcripts are saved
TRANSCRIPTS_DIR=/path/to/transcripts

# ─── Optional: Audio ──────────────────────────────────────────────────────────

# Folder where processed audio is moved after transcription (default: inbox/processed)
AUDIO_PROCESSED=/path/to/audio/processed

# Whisper model: tiny | base | small | medium | large-v2 | large-v3 (default: large-v3)
WHISPER_MODEL=large-v3

# Device: cuda (GPU, recommended) | cpu (default: cuda)
WHISPER_DEVICE=cuda

# Language: ru | en | auto (default: ru)
WHISPER_LANGUAGE=ru

# ─── Optional: Speaker diarization ────────────────────────────────────────────

# HuggingFace token — required for speaker diarization (pyannote.audio)
# Get at: https://huggingface.co/settings/tokens
# Accept terms at: https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=

# Enable diarization by default without --diarize flag (default: false)
DIARIZE_BY_DEFAULT=false

# ─── Optional: Analysis ───────────────────────────────────────────────────────

# Claude model for analysis (default: claude-haiku-4-5-20251001)
# Options: claude-haiku-4-5-20251001 (fast/cheap) | claude-sonnet-4-6 (better)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Path to custom analysis prompt file (default: prompts/meeting_analysis.txt)
ANALYSIS_PROMPT_FILE=

# Max tokens for analysis response (default: 4096)
ANALYSIS_MAX_TOKENS=4096

# ─── Optional: Meeting categories ─────────────────────────────────────────────

# Map subfolder names to human-readable category labels
# Format: subfolder=Label,subfolder2=Label2
# Example: MEETING_CATEGORIES=sales=Sales,finance=Finance,ops=Operations
MEETING_CATEGORIES=

# ─── Optional: Notion ─────────────────────────────────────────────────────────

# Notion integration token (leave empty to disable)
NOTION_TOKEN=

# Notion database ID for meeting records
NOTION_MEETINGS_DB=

# Notion parent page ID (fallback if database not set)
NOTION_PARENT_PAGE=

# ─── Optional: Pipeline behaviour ────────────────────────────────────────────

# Move audio to AUDIO_PROCESSED after transcription (default: true)
MOVE_AFTER_PROCESSING=true
