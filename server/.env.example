# ─── Required ─────────────────────────────────────────────────────────────────

# Groq API key for Whisper transcription (https://console.groq.com/)
GROQ_API_KEY=your_groq_key_here

# Claude API key for meeting analysis (https://console.anthropic.com/)
ANTHROPIC_API_KEY=your_anthropic_key_here

# PostgreSQL connection string
POSTGRES_DSN=postgresql://growth_user:GrowthCMO2026!Algora@10.0.0.2:5432/algora_growth

# ─── Optional: Server ────────────────────────────────────────────────────────

# Server host and port (container listens on 8080, nginx proxies from 8004)
HOST=0.0.0.0
PORT=8080

# Max upload file size in MB (default: 100)
UPLOAD_MAX_SIZE_MB=100

# ─── Optional: Whisper ───────────────────────────────────────────────────────

# Groq Whisper model (default: whisper-large-v3)
GROQ_MODEL=whisper-large-v3

# Language for transcription (default: ru)
WHISPER_LANGUAGE=ru

# ─── Optional: Claude ───────────────────────────────────────────────────────

# Claude model for analysis (default: claude-haiku-4-5-20251001)
# Options: claude-haiku-4-5-20251001 (fast/cheap) | claude-sonnet-4-6 (better)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Max tokens for analysis (default: 4096)
ANALYSIS_MAX_TOKENS=4096

# ─── Optional: Email notifications ─────────────────────────────────────────

# SMTP settings for email notifications (leave empty to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
NOTIFY_EMAIL=
