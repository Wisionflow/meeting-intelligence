# ─── Required ─────────────────────────────────────────────────────────────────

# Claude API key for meeting analysis (https://console.anthropic.com/)
ANTHROPIC_API_KEY=your_anthropic_key_here

# PostgreSQL connection string
POSTGRES_DSN=postgresql://growth_user:GrowthCMO2026!Algora@10.0.0.2:5432/algora_growth

# ─── Optional: Server ────────────────────────────────────────────────────────

# Server host and port (container listens on 8080, nginx proxies from 8004)
HOST=0.0.0.0
PORT=8080

# Max upload file size in MB (default: 100)
UPLOAD_MAX_SIZE_MB=100

# ─── Transcription backends (ordered by priority) ──────────────────────────

# Backend 1: Groq Whisper API (fast, free, cloud)
# Leave empty to skip → falls back to next backend
GROQ_API_KEY=
GROQ_MODEL=whisper-large-v3

# Backend 2: OpenAI Whisper API ($0.006/min, cloud)
# Leave empty to skip → falls back to local
OPENAI_API_KEY=

# Backend 3: Local faster-whisper (always available, no API keys needed)
# Model: tiny | base | small | medium | large-v2 | large-v3
WHISPER_MODEL=large-v3
# Device: cpu (server) | cuda (GPU)
WHISPER_DEVICE=cpu
# Compute type: int8 (CPU, fast) | float16 (GPU)
WHISPER_COMPUTE_TYPE=int8

# Language for all backends (default: ru)
WHISPER_LANGUAGE=ru

# ─── Optional: Claude ───────────────────────────────────────────────────────

# Claude model for analysis (default: claude-haiku-4-5-20251001)
# Options: claude-haiku-4-5-20251001 (fast/cheap) | claude-sonnet-4-6 (better)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Max tokens for analysis (default: 4096)
ANALYSIS_MAX_TOKENS=4096

# ─── Optional: Email notifications ─────────────────────────────────────────

# SMTP settings for email notifications (leave empty to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
NOTIFY_EMAIL=
